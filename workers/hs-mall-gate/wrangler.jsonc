{
  // hs-mall-gate : 八雲モール 認証ゲート（新規Worker / 既存には一切触れていない）
  "name": "hs-mall-gate",
  "main": "src/index.js",
  "compatibility_date": "2026-01-01",

  "kv_namespaces": [
    {
      "binding": "HS_PARTNER_KV",
      "id": "REPLACE_WITH_KV_ID"
    }
  ]

  // secret は wrangler secret put で手動投入する（vars には書かない / git に乗せない）:
  //   ADMIN_TOKEN        ... /admin/issue-key を守る管理トークン
  //   PRICE_ENGINE_URL   ... 本体の価格APIエンドポイント(oga-surf-project)
  //   PRICE_ENGINE_KEY   ... 本体への認証キー
}
