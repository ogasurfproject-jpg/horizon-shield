{
  // hs-gemini-audit : 自社サイト用「Gemini監査」エンドポイント
  "name": "hs-gemini-audit",
  "main": "src/index.js",
  "compatibility_date": "2025-06-01",
  "observability": { "enabled": true },
  "workers_dev": true,
  "services": [{ "binding": "HS_MCP", "service": "hs-mcp" }],
  "ratelimits": [{ "name": "AUDIT_RL", "namespace_id": "1001", "simple": { "limit": 15, "period": 60 } }]
}
