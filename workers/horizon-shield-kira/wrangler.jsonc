// ===================================================================
//  wrangler.jsonc  —  【救出・参照用スタブ / RESCUE REFERENCE STUB】
//  worker: horizon-shield-kira
//  用途: ★旧/初代 見込み客監視 v1.0。Google Alerts RSS→Claude(haiku)採点(閾値70)→LINE push。LEGACY候補。
//
//  ⚠ これは Cloudflare 上のデプロイ済みバンドルから救出したコードに
//     後付けした最小 wrangler 設定です。バージョン管理・可読性のためのもので、
//     この設定で「再デプロイする前提」では作られていません。
//     本番は今も Cloudflare 上でそのまま動いています（このファイルでは動いていない）。
//     万一これで再デプロイする時は、必ず下記プレースホルダを実値に直し、
//     compatibility_date / cron / KV id / secret をダッシュボードと突き合わせること。
//  NOTE: このworkerのソースは esbuild でバンドル済み(sourceMappingURLあり/.mapは取得不可)。
//        救出したのは“束ねられた実行コード”であり、元の分割ソースそのものではない。
// ===================================================================
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "horizon-shield-kira",
  "main": "src/worker.js",
  "compatibility_date": "2025-01-01",   // PLACEHOLDER: 実値はダッシュボード Settings→Runtime で確認
  "compatibility_flags": ["nodejs_compat"],  // PLACEHOLDER: 実際のflagに合わせる（不要なら削除）
  // トリガー: あり
  "triggers": { "crons": [ /* "実際のcron式をダッシュボードから" */ ] },
  "vars": {
    "LINE_USER_ID": "<PLAINTEXT_VAR_値をダッシュボードから>",
    "ALERT_FEED_URLS": "<PLAINTEXT_VAR_値をダッシュボードから>",
  },
  // secrets（値はコードに入れない。`npx wrangler secret put <NAME>` で設定・Cloudflare上に既存）:
  //   ANTHROPIC_API_KEY, LINE_CHANNEL_TOKEN
}
